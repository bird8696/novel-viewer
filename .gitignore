# Firebase 환경 변수 (API 키 포함)
.env
.env.local
.env.production
.env.development

# Firebase 설정 파일 (API 키 들어있음)
src/js/firebase-config.js

# Firebase 에뮬레이터
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Firebase 함수 (나중에 추가할 경우)
functions/node_modules/
functions/.env


