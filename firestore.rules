rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════
    // 유저 데이터 — 본인만 읽기/쓰기 가능
    // ══════════════════════════════════════
    match /users/{userId}/{document=**} {

      // 로그인한 본인만 접근 가능
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ══════════════════════════════════════
    // 그 외 모든 경로 — 전부 차단
    // ══════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
